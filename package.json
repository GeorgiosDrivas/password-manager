  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.6",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "husky": "^9.1.7",
    "prettier": "^3.8.1",
    "shadcn": "^3.8.5",
    "typescript-eslint": "^8.56.1"
  }
